{
  "name": "@tooooools/ui",
  "version": "2.5.0",
  "description": "JSX ui kit built for Toools™",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "start": "storybook dev -p 6006 --no-open",
    "example": "vite --config example/vite.config.js",
    "build": "vite build",
    "build:watch": "vite build --mode dev",
    "build:docs": "storybook build -o docs && touch ./docs/.nojekyll",
    "preversion": "yarn test && yarn build && yarn build:docs && git add -f dist",
    "postversion": "git push && git push --tags && ghp docs -f && npm publish --access public"
  },
  "author": "Arnaud Juracek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:tooooools/ui.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/jsx.js",
      "require": "./dist/jsx.cjs"
    },
    "./state": {
      "import": "./dist/state.js",
      "require": "./dist/state.cjs"
    },
    "./components": {
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    },
    "./style": "./dist/style.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.cjs",
  "devDependencies": {
    "@storybook/addon-console": "^3.0.0",
    "@storybook/html-vite": "^9.0.17",
    "@storybook/testing-library": "^0.2.2",
    "eslint": "^9.31.0",
    "eslint-plugin-storybook": "^9.0.17",
    "ghp": "^1.7.0",
    "iconoir": "^6.11.0",
    "neostandard": "^0.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.89.2",
    "storybook": "^9.0.17",
    "string-hash": "^1.1.3",
    "stylelint": "^15.3.0",
    "stylelint-config-standard-scss": "^7.0.1",
    "stylelint-order": "^6.0.3",
    "stylelint-scss": "^4.5.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.8"
  },
  "resolutions": {
    "jackspeak": "2.1.1"
  },
  "dependencies": {
    "debounce": "^1.2.1"
  }
}
